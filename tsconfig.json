{
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"],
  "compilerOptions": {
    "target": "ES2022", /* Modern target for Node.js 18+ performance */
    "module": "NodeNext", /* Essential for modern package compatibility */
    "moduleResolution": "NodeNext",
    "rootDir": "./src",
    "outDir": "./dist",
    
    /* Interop Constraints */
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,

    /* Strictness */
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "noImplicitThis": true,
    "useUnknownInCatchVariables": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,

    /* Emit */
    "sourceMap": true, /* Crucial for debugging production errors */
    "removeComments": true,
    "noEmitOnError": true,
    
    /* Advanced (For NestJS-like patterns or complex architectures) */
    "experimentalDecorators": true, 
    "emitDecoratorMetadata": true,

    /* Completeness */
    "skipLibCheck": true 
  }
}